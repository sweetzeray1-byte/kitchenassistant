# Kitchen Assistant web — environment template
# Copy to .env.local and fill in values.

# Backend API base URL
# Production: https://delisio-production.up.railway.app
# Local dev:  http://localhost:3002
NEXT_PUBLIC_API_BASE_URL=https://delisio-production.up.railway.app

# Supabase project (use the public ANON key only — never the service-role key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
